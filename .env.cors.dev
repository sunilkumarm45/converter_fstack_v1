# CORS Configuration - Development Environment Template
# Copy this to your .env.dev file or set in docker-compose.dev.yml

# CORS Allowed Origins (comma-separated)
# Default includes common local development URLs
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://127.0.0.1:5173,http://127.0.0.1:3000,http://127.0.0.1:8080

# CORS Allowed HTTP Methods (comma-separated)
# Development allows all common methods for testing
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,HEAD,PATCH

# CORS Allowed Headers (comma-separated, or * for all)
# Permissive in development
CORS_ALLOWED_HEADERS=*

# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=true

# Preflight request cache duration (seconds)
# 1 hour is good for development
CORS_MAX_AGE=3600

# ==============================================================================
# Notes:
# - Add your custom frontend URLs if running on different ports
# - These settings are permissive for local development convenience
# - The defaults work for standard Vite (5173) and Grafana (3000) setups
# ==============================================================================

