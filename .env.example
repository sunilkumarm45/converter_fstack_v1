# Currency Converter Environment Variables

# ===========================================
# Swop.cx API Configuration
# ===========================================
# Get your API key from https://swop.cx/
# The application will use fallback rates if not provided
SWOP_API_KEY=

# ===========================================
# InfluxDB Configuration
# ===========================================
INFLUX_ENABLED=true
INFLUX_BUCKET=metrics
INFLUX_ORG=converter
INFLUX_TOKEN=default-token
MANAGEMENT_METRICS_EXPORT_INFLUX_URI=http://influxdb:8086

# ===========================================
# Grafana Configuration
# ===========================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ===========================================
# Application Environment
# ===========================================
ENVIRONMENT=development

