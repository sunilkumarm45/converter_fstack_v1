# Development Environment Configuration
# Copy this to .env and fill in your values for local development

# Application Environment
ENVIRONMENT=development

# Swop.cx API Configuration (Get your key from https://swop.cx)
SWOP_API_KEY=0c940d5dab6d0d1361e2999137f3b21b641361bfae9636ef5bb3c2cd971350d9
SWOP_API_BASE_URL=https://swop.cx/rest

# InfluxDB Configuration (for metrics)
INFLUX_ENABLED=true
MANAGEMENT_METRICS_EXPORT_INFLUX_URI=http://influxdb:8086
INFLUX_BUCKET=metrics
INFLUX_ORG=converter
INFLUX_TOKEN=default-token

# InfluxDB Setup (Docker Compose)
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=adminpassword
DOCKER_INFLUXDB_INIT_ORG=converter
DOCKER_INFLUXDB_INIT_BUCKET=metrics
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=default-token

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_INSTALL_PLUGINS=

# Backend Configuration
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Frontend Configuration
VITE_GRAPHQL_URL=http://localhost:8080/graphql
FRONTEND_PORT=5173

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_CONVERTER=DEBUG

